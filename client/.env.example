EXPO_PUBLIC_API_URL=http://localhost:9003
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Sentry (crash reporting) — see docs/sentry.md
# Public DSN (safe in the client bundle; used at runtime by the SDK)
EXPO_PUBLIC_SENTRY_DSN=
# Org / project slugs (build-time; used by the Expo config plugin)
SENTRY_ORG=
SENTRY_PROJECT=
# Organization auth token for source map + debug symbol upload (NEVER commit)
# Local: put in .env or .env.local | EAS: set as a sensitive environment variable
SENTRY_AUTH_TOKEN=
