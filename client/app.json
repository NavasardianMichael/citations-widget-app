{
  "expo": {
    "name": "Մեջբերումներ Աստվածաշնչից",
    "slug": "citations-widget-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "citationswidget",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.citationswidgetapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fbf9f8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.citationswidgetapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [{ "scheme": "citationswidget" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fbf9f8",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 128
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.anonymous.citationswidgetapp.widgets",
          "groupIdentifier": "group.com.anonymous.citationswidgetapp",
          "widgets": [
            {
              "name": "CitationWidget",
              "displayName": "Մեջբերումներ Աստվածաշնչից",
              "description": "Մեջբերումներ ձեր գլխավոր էկրանին",
              "contentMarginsDisabled": true,
              "supportedFamilies": ["systemSmall", "systemMedium", "systemLarge"]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "fonts": [
            "./assets/fonts/vrdznagir/Vrdznagir.otf",
            "./assets/fonts/braind-amanor/BraindAmanor.otf",
            "./assets/fonts/artsakh/Artsakh.otf",
            "./assets/fonts/davel-aghvor/davel-aghvor.otf",
            "./assets/fonts/mardoto/Mardoto-Regular.ttf",
            "./assets/fonts/arti/Arti-Regular.otf",
            "./assets/fonts/arian-grqi/Arian_Grqi_U.ttf",
            "./assets/fonts/braind-zbans/BraindZbans.otf",
            "./assets/fonts/nortar-body/NorTarBody.otf",
            "./assets/fonts/arm-hmks-script/ArmHmksScript.ttf",
            "./assets/fonts/noyemi/Noyemi.otf",
            "./assets/fonts/armeniapedia-garun/ArmeniapediaGarun.ttf",
            "./assets/fonts/armeniapedia-geghagrutyun/ArmeniapediaGeghagrutyun.ttf",
            "./assets/fonts/sasuntsi/Sasuntsi-Regular.ttf",
            "./assets/fonts/armeniapedia-jhapaven/ArmeniapediaJhapaven.ttf"
          ],
          "widgets": [
            {
              "name": "CitationWidget",
              "label": "Մեջբերումներ Աստվածաշնչից",
              "description": "Մեջբերումներ ձեր գլխավոր էկրանին",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
