NODE_ENV=development
PORT=3001
LOG_LEVEL=info

DATABASE_URL=postgresql://citations:citations@localhost:5433/citations
REDIS_URL=redis://localhost:6380

SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
SESSION_MAX_AGE=604800000

JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Deep link base for mobile email links (Expo scheme)
CLIENT_URL=citationswidget://

API_URL=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

MAIL_API_URL=
MAIL_API_KEY=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

MAX_CONCURRENT_SESSIONS=5
